<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CSharpEmilyApp.ViewModels"
             xmlns:api="using:CSharpEmilyApp.API"
             x:Class="CSharpEmilyApp.Views.PlanningView"
             x:DataType="vm:PlanningViewModel">
    
    <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock Grid.Row="0" IsVisible="{Binding isLoading}"
                   Text="...loading"/>
        
        <TextBlock Grid.Row="1"
            IsVisible="{Binding Error}"
            Text="{Binding Error}"
            Foreground="red"
            />
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl Grid.Row="1" ItemsSource="{Binding PlanningResponse.Results}"
                          IsVisible="{Binding !isLoading}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="api:GetPlanning+PlanningResponse">
                        <StackPanel>
                            <TextBlock Text="{Binding Id }"/>
                            <TextBlock Text="{Binding StartDate}"/>
                            <TextBlock Text="{Binding EndDate}"/>
                            <TextBlock Text="{Binding Number}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>

</UserControl>