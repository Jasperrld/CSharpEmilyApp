       <Grid Grid.Row="3" ColumnDefinitions="150,*">
            <!-- Datum kolom vast, scrollt alleen verticaal mee via sync -->
            <Grid Grid.Column="0" RowDefinitions="40,*">
                <Border Grid.Row="0"
                        Height="40"
                        BorderBrush="#ddd"
                        BorderThickness="0,0,1,1"
                        Padding="8"
                        Background="#f0f0f0">
                    <TextBlock Text="Datum" FontWeight="Bold" VerticalAlignment="Center"/>
                </Border>
                <ScrollViewer Grid.Row="1"
                              Name="DateScroll"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding PlanningRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlanningRow">
                                <Border BorderBrush="#ddd"
                                        BorderThickness="0,0,1,1"
                                        Padding="8"
                                        Height="{Binding RowHeight}">
                                    <TextBlock Text="{Binding DayName}"
                                               VerticalAlignment="Top"
                                               TextWrapping="NoWrap"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Machine kolommen -->
            <Grid Grid.Column="1" RowDefinitions="40,*">
                <!-- Machine namen header -->
                <ScrollViewer Grid.Row="0"
                              Height="40"
                              Name="HeaderScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding MachineNames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Width="200"
                                        Height="40"
                                        BorderBrush="#ddd"
                                        BorderThickness="0,0,1,1"
                                        Padding="8"
                                        Background="#f0f0f0">
                                    <TextBlock Text="{Binding}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Content -->
                <ScrollViewer Grid.Row="1"
                              Name="ContentScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PlanningRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlanningRow">
                                <ItemsControl ItemsSource="{Binding Cells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:PlanningCell">
                                            <Border Width="200"
                                                    Height="{Binding RowHeight}"
                                                    BorderBrush="#ddd"
                                                    BorderThickness="0,0,1,1"
                                                    Padding="8">
                                                <ItemsControl ItemsSource="{Binding Jobs}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:PlanningJob">
                                                            <Border Background="#e8f4f8"
                                                                    CornerRadius="4"
                                                                    Padding="6"
                                                                    Margin="0,0,0,4">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding MachineName}"
                                                                               FontSize="11"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding OrderNumber}"
                                                                               FontWeight="Bold"
                                                                               FontSize="12"/>
                                                                    <TextBlock Text="{Binding Company}"
                                                                               FontSize="11"/>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               FontSize="11"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

    </Grid>
</UserControl>