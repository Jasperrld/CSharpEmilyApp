<UserControl 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CSharpEmilyApp.ViewModels"
    xmlns:comp="using:CSharpEmilyApp.Views.Components"
    x:Class="CSharpEmilyApp.Views.PlanningView"
    x:DataType="vm:PlanningViewModel"
    
>
    <Grid>
        <!-- Loading -->
        <TextBlock IsVisible="{Binding IsLoading}"
                   Text="Loading..."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- Error -->
        <TextBlock IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Text="{Binding Error}"
                   Foreground="Red"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- Data -->
        <StackPanel IsVisible="{Binding !IsLoading}">
            <TextBlock Text="{Binding PlanningResponse.id}"/>
        </StackPanel>
    </Grid>
    
</UserControl>