<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CSharpEmilyApp.ViewModels"
             xmlns:api="using:CSharpEmilyApp.API"
             x:Class="CSharpEmilyApp.Views.PlanningView"
             x:DataType="vm:PlanningViewModel">
    
    <Grid>
        <TextBlock IsVisible="{Binding isLoading}"
                   Text="...loading"/>
        
        <TextBlock
            IsVisible="{Binding Error}"
            Text="{Binding Error}"
            Foreground="red"
            />
        <ItemsControl ItemsSource="{Binding PlanningResponse.Results}"
                      IsVisible="{Binding !isLoading}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="api:GetPlanning+PlanningResponse">
                    <StackPanel>
                        <TextBlock Text="{Binding Id }"/>
                    </StackPanel>
                    
                </DataTemplate>
                
            </ItemsControl.ItemTemplate>
            
        </ItemsControl>
    </Grid>

</UserControl>