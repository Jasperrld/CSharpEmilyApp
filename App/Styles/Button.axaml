<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Button.nav-button">
        <Setter Property="Background" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="Button.nav-button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#C4E2EC"/>
    </Style>
    
    <Style Selector="Button.nav-button:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#C4E2EC"/>
    </Style>
    
    <Style Selector="Button.nav-button-active /template/ ContentPresenter">
        <Setter Property="Background" Value="#0089B4"/>
    </Style>
</Styles>